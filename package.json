{
  "name": "@forkcast/pm-lean",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "pm-lean": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "ingest": "tsx src/cli.ts ingest",
    "derive": "tsx src/cli.ts derive",
    "backfill": "tsx src/cli.ts backfill",
    "live-fixture": "tsx src/cli.ts live-fixture",
    "dummy": "tsx src/cli.ts dummy",
    "manifest": "tsx src/cli.ts manifest",
    "dispatch": "tsx src/cli.ts dispatch",
    "verify": "npm run typecheck && npm run test && npm run build"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
